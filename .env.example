DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_LM_PREFIX=!lm

LMS_BINARY=/home/cadmus/.lmstudio/bin/lms
LMS_DEFAULT_CONTEXT_LENGTH=16384
LMS_DEFAULT_TTL_SECONDS=0
LMS_MIN_FREE_MEMORY_MB=700
LMS_PS_TIMEOUT_SECONDS=10

LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# Runtime active model identifier. The bot updates this when !lm use/load changes models.
LM_STUDIO_MODEL=qwen3.5-0.8b
LM_STUDIO_TIMEOUT_SECONDS=600
LM_STUDIO_SYSTEM_PROMPT=You are a concise, helpful assistant in Discord. Answer naturally and keep replies practical. Discord does not render LaTeX, so never use LaTeX or math delimiters like $...$. Write equations in plain text, such as epsilon_r, epsilon_0, >=, <=, x 10^-12, and F/m.

BOT_LOG_PATH=bot.log
BOT_LOG_MAX_BYTES=1000000
BOT_LOG_BACKUP_COUNT=3
BOT_MAX_QUEUE_SIZE=3
BOT_USER_COOLDOWN_SECONDS=2
WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDER=bing
WEB_SEARCH_MAX_RESULTS=4
WEB_SEARCH_TIMEOUT_SECONDS=12
WEB_SEARCH_USER_AGENT=Mozilla/5.0 (compatible; lm-studio-discord-bot/1.0)
# Optional: set WEB_SEARCH_PROVIDER=searxng and provide your instance URL, or use WEB_SEARCH_PROVIDER=duckduckgo.
SEARXNG_BASE_URL=

WIKI_SEARCH_ENABLED=true
WIKI_BASE_URL=http://127.0.0.1:8090
WIKI_MAX_RESULTS=3
WIKI_TIMEOUT_SECONDS=12
WIKI_ARTICLE_CHARS=700
